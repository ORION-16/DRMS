<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DRMS</title>
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Framework -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <!-- Custom Styles -->
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <div class="app-wrapper">
        <aside class="sidebar">
            @{
                var brandUrl = "/Account/Login";
                if (User.Identity?.IsAuthenticated == true)
                {
                    var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                    brandUrl = userRole switch
                    {
                        "Developer" => "/Dashboard/Index",
                        "TechLead" or "QA" or "DevOps" => "/Approval/Pending",
                        "Admin" => "/Admin/Index",
                        _ => "/Account/Login"
                    };
                }
            }
            <a class="brand shiny-text" href="@brandUrl">
                <i class="bi bi-hexagon-fill me-2 text-gradient"></i> DRMS
            </a>

            <nav class="nav flex-column mb-auto">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                    var action = ViewContext.RouteData.Values["action"]?.ToString();

                    if (role == "Developer")
                    {
                        <div class="nav-item">
                            <a class="nav-link @(controller == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-grid-1x2"></i> Dashboard
                            </a>
                        </div>
                        <div class="nav-item mt-2">
                            <a class="nav-link @(controller == "Deployment" && action == "Create" ? "active" : "")" asp-controller="Deployment" asp-action="Create">
                                <i class="bi bi-plus-square"></i> New Request
                            </a>
                        </div>
                    }
                    else if (role == "TechLead" || role == "QA" || role == "DevOps")
                    {
                        <div class="nav-item">
                            <a class="nav-link @(controller == "Approval" && action == "Pending" ? "active" : "")" asp-controller="Approval" asp-action="Pending">
                                <i class="bi bi-inbox"></i> Pending Approvals <span class="badge bg-primary ms-auto rounded-circle">3</span>
                            </a>
                        </div>
                    }
                    else if (role == "Admin")
                    {
                        <div class="nav-item">
                            <a class="nav-link @(controller == "Admin" ? "active" : "")" asp-controller="Admin" asp-action="Index">
                                <i class="bi bi-shield-check"></i> Overview
                            </a>
                        </div>
                    }
                }
            </nav>

            @if (User.Identity?.IsAuthenticated == true)
            {
                var userName = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value;
                var userRole = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                
                <div class="user-profile mt-4">
                    <div class="user-avatar">
                        @userName?.Substring(0, 1).ToUpper()
                    </div>
                    <div class="d-flex flex-column me-auto">
                        <span class="text-white fw-bold small">@userName</span>
                        <span class="text-secondary" style="font-size: 0.75rem;">@userRole <span class="badge bg-secondary bg-opacity-25 ms-1">PRO</span></span>
                    </div>
                    <a asp-controller="Account" asp-action="Logout" class="text-secondary ms-2" title="Logout">
                        <i class="bi bi-box-arrow-right"></i>
                    </a>
                </div>
            }
        </aside>

        <main class="main-content">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show border-0 bg-success bg-opacity-10 text-success" role="alert">
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show border-0 bg-danger bg-opacity-10 text-danger" role="alert">
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
