@model string

@if (Model == "Submitted")
{
    <span class="badge bg-primary">@Model</span>
}
else if (Model == "TechLead Approved")
{
    <span class="badge bg-info text-dark">@Model</span>
}
else if (Model == "QA Approved")
{
    <span class="badge" style="background-color: #6f42c1;">@Model</span>
}
else if (Model == "Deployed")
{
    <span class="badge bg-success">@Model</span>
}
else if (Model == "Rejected")
{
    <span class="badge bg-danger">@Model</span>
}
else if (Model == "Returned For Changes")
{
    <span class="badge bg-warning text-dark">@Model</span>
}
else if (Model == "Cancelled")
{
    <span class="badge bg-secondary">@Model</span>
}
else if (Model == "Rolled Back")
{
    <span class="badge bg-dark">@Model</span>
}
else
{
    <span class="badge bg-light text-dark">@Model</span>
}
