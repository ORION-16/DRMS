@model DRMS.Application.DTOs.DeploymentRequestDto
@{
    ViewData["Title"] = $"History - {Model.RequestNumber}";
}

<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2 class="fw-bold mb-0 text-white">Full History: @Model.RequestNumber</h2>
    <a asp-action="Index" class="btn btn-outline-light btn-magnet shadow-sm">Back to Dashboard</a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="glass-panel p-0 mb-4">
            <div class="p-4 border-bottom border-secondary border-opacity-25">
                <h5 class="mb-0 fw-bold text-white">Request Context</h5>
            </div>
            <div class="p-4">
                <p class="mb-3"><strong class="text-secondary small d-block mb-1">PROJECT</strong> <span class="text-white">@Model.ProjectName</span></p>
                <p class="mb-3"><strong class="text-secondary small d-block mb-1">ENVIRONMENT</strong> <span class="text-white">@Model.EnvironmentName</span></p>
                <p class="mb-3"><strong class="text-secondary small d-block mb-1">SOURCE BRANCH</strong> <code class="text-danger">@Model.SourceBranch</code></p>
                <p class="mb-0"><strong class="text-secondary small d-block mb-1">CURRENT STATUS</strong> <partial name="_StatusBadge" model="Model.CurrentStatus" /></p>
            </div>
        </div>
    </div>
    
    <div class="col-md-8">
        <div class="glass-panel p-0">
            <div class="p-4 border-bottom border-secondary border-opacity-25">
                <h5 class="mb-0 fw-bold text-white">Complete Audit Trail</h5>
            </div>
            <div class="p-0">
                <div class="table-responsive pb-4">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th>Date/Time</th>
                                <th>Action By</th>
                                <th>Role</th>
                                <th>Action Taken</th>
                                <th>Remarks</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td class="text-white">@Model.RequestedDate.ToString("g")</td>
                                <td>@Model.RequestedByName</td>
                                <td>Developer</td>
                                <td class="text-primary fw-bold">Submitted</td>
                                <td class="text-secondary small">Initial request created</td>
                            </tr>
                            @foreach (var approval in Model.Approvals)
                            {
                                <tr>
                                    <td class="text-white">@approval.ActionDate.ToString("g")</td>
                                    <td>@approval.ApproverName</td>
                                    <td>@approval.ApproverRole</td>
                                    <td class="@(approval.ActionTaken == "Rejected" ? "text-danger" : "text-success") fw-bold">@approval.ActionTaken</td>
                                    <td class="small text-secondary">@approval.Remarks</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
